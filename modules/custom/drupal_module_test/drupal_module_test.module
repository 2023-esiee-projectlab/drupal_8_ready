<?php

/**
 * Implements hook_menu().
 */
function custom_module_menu(): array
{
  $items['testModule'] = array(
    'title' => 'My Custom Page',
    'page callback' => '\Drupal\drupal_module_test\Controller\EnsPageController::helloWord',
    'access arguments' => array('access content'),
  );

  return $items;
}

